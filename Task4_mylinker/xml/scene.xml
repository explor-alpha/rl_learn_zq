<mujoco model="linker_hand_grasp">
  <compiler angle="radian" meshdir="meshes/"/>

  <asset>
    <!-- 这里保留你之前那一堆 <mesh ... /> 标签 -->
    <mesh name="hand_base_link" file="hand_base_link.STL"/>
    <mesh name="thumb_metacarpals_base2" file="thumb_metacarpals_base2.STL"/>
    <mesh name="thumb_metacarpals" file="thumb_metacarpals.STL"/>
    <mesh name="thumb_distal" file="thumb_distal.STL"/>
    <mesh name="index_proximal" file="index_proximal.STL"/>
    <mesh name="index_distal" file="index_distal.STL"/>
    <mesh name="middle_proximal" file="middle_proximal.STL"/>
    <mesh name="middle_distal" file="middle_distal.STL"/>
    <mesh name="ring_proximal" file="ring_proximal.STL"/>
    <mesh name="ring_distal" file="ring_distal.STL"/>
    <mesh name="pinky_proximal" file="pinky_proximal.STL"/>
    <mesh name="pinky_distal" file="pinky_distal.STL"/>
  </asset>

  <worldbody>
    <!-- 添加灯光和地板 -->
    <light pos="0 0 3"/>
    <geom type="plane" size="1 1 0.1" rgba="0.8 0.8 0.8 1"/>

    <!-- 你的机器手主体结构 -->
    <geom type="mesh" rgba="0.5 0.5 0.52 1" mesh="hand_base_link"/>
    
    <!-- ... 这里粘贴你之前所有的 <body name="rh_thumb_..."> 结构 ... -->
    <body name="rh_thumb_metacarpals_base2" pos="0.011508 0.022975 0.032794">
      <inertial pos="0.00162796 0.00276672 -0.00184228" quat="0.958658 0.114191 -0.0354615 -0.258221" mass="0.00138591" diaginertia="5.49427e-08 4.70357e-08 2.7769e-08"/>
      <joint name="rh_thumb_cmc_yaw" pos="0 0 0" axis="0 0 -1" range="0 1.36" actuatorfrcrange="-100 100"/>
      <geom type="mesh" rgba="0.15 0.15 0.15 1" mesh="thumb_metacarpals_base2"/>
      <body name="rh_thumb_metacarpals" pos="0.0061649 0.010678 -0.004891" quat="0.4192 -0.472029 -0.272524 -0.726079">
        <inertial pos="4.24921e-05 -1.67886e-05 0.0228342" quat="0.687228 -0.164922 -0.164643 0.688049" mass="0.0123382" diaginertia="1.76758e-06 1.16101e-06 8.78264e-07"/>
        <joint name="rh_thumb_cmc_pitch" pos="0 0 0" axis="0 1 0" range="0 0.58" actuatorfrcrange="-100 100"/>
        <geom type="mesh" rgba="0.5 0.5 0.52 1" mesh="thumb_metacarpals"/>
        <body name="rh_thumb_distal" pos="0.0037776 0 0.045368">
          <inertial pos="-0.00413691 -4.54843e-07 0.0230097" quat="0.999397 9.12706e-06 -0.0347342 -8.13325e-06" mass="0.00763303" diaginertia="1.31047e-06 1.22457e-06 2.72295e-07"/>
          <joint name="rh_thumb_ip" pos="0 0 0" axis="0 1 0" range="0 1.08" actuatorfrcrange="-100 100"/>
          <geom type="mesh" rgba="0.5 0.5 0.52 1" mesh="thumb_distal"/>
        </body>
      </body>
    </body>
    <body name="rh_index_proximal" pos="0.0024758 0.02419 0.098779" quat="0.999657 -0.026177 0 0">
      <inertial pos="-0.00208666 -4.8965e-06 0.0172737" quat="0.993795 0.000369213 -0.111225 0.0007939" mass="0.00253179" diaginertia="2.75761e-07 2.72916e-07 7.58316e-08"/>
      <joint name="rh_index_mcp_pitch" pos="0 0 0" axis="0 1 0" range="0 1.6" actuatorfrcrange="-100 100"/>
      <geom type="mesh" rgba="0.5 0.5 0.52 1" mesh="index_proximal"/>
      <body name="rh_index_distal" pos="-0.0052516 0 0.036625">
        <inertial pos="0.0065894 -4.59977e-06 0.0194434" quat="0.97709 0.000756952 0.212768 0.00487986" mass="0.00376787" diaginertia="3.74403e-07 3.65131e-07 7.19711e-08"/>
        <joint name="rh_index_dip" pos="0 0 0" axis="0 1 0" range="0 1.43" actuatorfrcrange="-100 100"/>
        <geom type="mesh" rgba="0.5 0.5 0.52 1" mesh="index_distal"/>
      </body>
    </body>
    <body name="rh_middle_proximal" pos="0.00052576 0.00634 0.1027">
      <inertial pos="-0.00208661 -4.93452e-06 0.0172737" quat="0.993795 0.000375852 -0.111225 0.000731327" mass="0.00253175" diaginertia="2.75761e-07 2.72915e-07 7.58309e-08"/>
      <joint name="rh_middle_mcp_pitch" pos="0 0 0" axis="0 1 0" range="0 1.6" actuatorfrcrange="-100 100"/>
      <geom type="mesh" rgba="0.5 0.5 0.52 1" mesh="middle_proximal"/>
      <body name="rh_middle_distal" pos="-0.0052516 0 0.036625">
        <inertial pos="0.0065894 -4.58857e-06 0.0194435" quat="0.97709 0.000755208 0.212768 0.00486939" mass="0.00376786" diaginertia="3.74402e-07 3.6513e-07 7.19708e-08"/>
        <joint name="rh_middle_dip" pos="0 0 0" axis="0 1 0" range="0 1.43" actuatorfrcrange="-100 100"/>
        <geom type="mesh" rgba="0.5 0.5 0.52 1" mesh="middle_distal"/>
      </body>
    </body>
    <body name="rh_ring_proximal" pos="0.0010258 -0.011135 0.098767" quat="0.999657 0.026177 0 0">
      <inertial pos="-0.00208654 -4.98539e-06 0.0172737" quat="0.993795 0.000384813 -0.111226 0.000649851" mass="0.00253171" diaginertia="2.7576e-07 2.72915e-07 7.58301e-08"/>
      <joint name="rh_ring_mcp_pitch" pos="0 0 0" axis="0 1 0" range="0 1.6" actuatorfrcrange="-100 100"/>
      <geom type="mesh" rgba="0.5 0.5 0.52 1" mesh="ring_proximal"/>
      <body name="rh_ring_distal" pos="-0.0052516 0 0.036625">
        <inertial pos="0.0065894 -4.56629e-06 0.0194435" quat="0.97709 0.000751861 0.21277 0.00484872" mass="0.00376784" diaginertia="3.744e-07 3.65127e-07 7.197e-08"/>
        <joint name="rh_ring_dip" pos="0 0 0" axis="0 1 0" range="0 1.43" actuatorfrcrange="-100 100"/>
        <geom type="mesh" rgba="0.5 0.5 0.52 1" mesh="ring_distal"/>
      </body>
    </body>
    <body name="rh_pinky_proximal" pos="0.0024758 -0.028372 0.092741" quat="0.999048 0.0436192 0 0">
      <inertial pos="-0.00208649 -5.02315e-06 0.0172737" quat="0.993795 0.0003914 -0.111226 0.000590247" mass="0.00253167" diaginertia="2.7576e-07 2.72914e-07 7.58294e-08"/>
      <joint name="rh_pinky_mcp_pitch" pos="0 0 0" axis="0 1 0" range="0 1.6" actuatorfrcrange="-100 100"/>
      <geom type="mesh" rgba="0.5 0.5 0.52 1" mesh="pinky_proximal"/>
      <body name="rh_pinky_distal" pos="-0.0052516 0 0.036625">
        <inertial pos="0.0065894 -4.55268e-06 0.0194435" quat="0.97709 0.000749893 0.21277 0.00483566" mass="0.00376783" diaginertia="3.74398e-07 3.65126e-07 7.19694e-08"/>
        <joint name="rh_pinky_dip" pos="0 0 0" axis="0 1 0" range="0 1.43" actuatorfrcrange="-100 100"/>
        <geom type="mesh" rgba="0.5 0.5 0.52 1" mesh="pinky_distal"/>
      </body>
    </body>


    <!-- 在 worldbody 的最后，添加你的目标方块 -->
    <body name="fragile_object" pos="0.1 0 0.1">
        <freejoint/>
        <geom name="object_geom" type="box" size="0.02 0.02 0.02" rgba="1 0 0 1" mass="0.05"/>
    </body>
  </worldbody>

  <!-- 1. 联动约束：让指尖跟着根部一起动（根据你之前的 URDF 比例） -->
  <equality>
    <joint joint1="rh_thumb_cmc_pitch" joint2="rh_thumb_ip" polycoef="0 1.86 0 0 0"/>
    <joint joint1="rh_index_mcp_pitch" joint2="rh_index_dip" polycoef="0 0.89 0 0 0"/>
    <joint joint1="rh_middle_mcp_pitch" joint2="rh_middle_dip" polycoef="0 0.89 0 0 0"/>
    <joint joint1="rh_ring_mcp_pitch" joint2="rh_ring_dip" polycoef="0 0.89 0 0 0"/>
    <joint joint1="rh_pinky_mcp_pitch" joint2="rh_pinky_dip" polycoef="0 0.89 0 0 0"/>
  </equality>

  <!-- 2. 执行器：这就是 AI 最终下发控制指令的通道 -->
  <actuator>
    <!-- 我们只为那 6 个主控关节添加马达，kp 是控制增益（力量感） -->
    <position name="act_thumb_yaw"   joint="rh_thumb_cmc_yaw"   kp="10"/>
    <position name="act_thumb_pitch" joint="rh_thumb_cmc_pitch" kp="10"/>
    <position name="act_index"       joint="rh_index_mcp_pitch" kp="10"/>
    <position name="act_middle"      joint="rh_middle_mcp_pitch" kp="10"/>
    <position name="act_ring"        joint="rh_ring_mcp_pitch"   kp="10"/>
    <position name="act_pinky"       joint="rh_pinky_mcp_pitch"  kp="10"/>
  </actuator>
  



</mujoco>